      "heading": "Home address in Canada",
      "heading_level": "h3",
      "category": "processing_information",
      "items": [
        "Enter the minor’s current home address (where the minor lives)."
      ],
      "bullets": [
        "Apartment (Apt.) or Unit, if it applies",
