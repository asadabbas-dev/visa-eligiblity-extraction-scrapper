    {
      "heading": "Apply through Express Entry",
      "heading_level": "h3",
      "category": "eligibility_criteria",
      "items": [
        "This option applies to you if you qualify for both the province or territory’s PNP stream and a federal program under Express Entry .",
        "If you’re nominated, create your Express Entry profile. You’ll get 600 extra points , which helps you get invited to apply for permanent residence."
      ],
