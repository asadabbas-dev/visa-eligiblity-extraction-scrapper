    {
      "heading": "Who can use this account",
      "heading_level": "h3",
      "category": "eligibility_criteria",
      "items": [
        "You may be able to use the IRCC Portal – New version if you meet all of the following requirements:"
      ],
      "bullets": [
        "You’re applying online for a visitor visa or super visa.",
        "You’re 18 years of age or older.",
        "You have never applied for anything with us before.",
        "You’re applying alone.",
        "You aren’t using a representative (including family or friends applying for you)."
      ],
      "tables": []
    },
    {
      "heading": "Planning to attend a FIFA World Cup 2026TM match?",
      "heading_level": "h3",
      "category": "application_steps",
      "items": [
        "You must use the IRCC Portal to apply for a visitor visa if you’re coming to Canada for a FIFA World Cup 2026TM match either",
        "You won’t be able to apply using the IRCC Portal – New version.",
        "Go to the IRCC Portal"
      ],
      "bullets": [
        "as a fan, or",
        "because you’ve been invited by FIFA"
      ],
