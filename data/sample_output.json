      "heading": "Eligibility requirements",
      "heading_level": "h3",
      "category": "eligibility_criteria",
      "items": [
        "You must have a valid passport or travel document.",
        "You must be in good health.",
        "You must not have criminal or immigration-related convictions.",
        "You must convince an officer that you have ties to your home country.",
        "You must show that you will leave Canada at the end of your authorized stay.",
        "You must show that you have enough money for your stay."
      ],
      "bullets": [
        "You may need a medical exam.",
        "A letter of invitation from someone in Canada can support your application."
      ],
